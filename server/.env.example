# ==========================================================
# ZERA XII backend - environment variables
# Copy this file to ".env" and fill in your real values.
# NEVER commit the real ".env" file to git.
# ==========================================================

# Port the API server runs on locally
PORT=5000

# MongoDB connection string.
# Local MongoDB example:      mongodb://127.0.0.1:27017/zeraxii
# MongoDB Atlas (free tier) example:
#   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/zeraxii?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/zeraxii

# Any long random string - used to sign login sessions (JWT).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-before-going-live

# The store owner's admin login email (already set to your email per your request)
ADMIN_EMAIL=aderinwaleblessing@gmail.com

# The FIRST-TIME dummy password for the admin account.
# She will be forced to change this the very first time she logs in.
# Change this to whatever you like before the first server start.
ADMIN_DEFAULT_PASSWORD=ZeraXII-Welcome2026

# ---------------- Gmail (for sending "forgot password" codes) ----------------
# GMAIL_USER should be the Gmail address that SENDS the reset code emails.
# GMAIL_APP_PASSWORD is NOT your normal Gmail password - it's a 16-character
# "App Password" you generate from your Google Account.
# How to get one:
#   1. Go to https://myaccount.google.com/security
#   2. Turn on 2-Step Verification (required for App Passwords)
#   3. Go to https://myaccount.google.com/apppasswords
#   4. Create an app password named "ZERA XII" and paste the 16-char code below
GMAIL_USER=aderinwaleblessing@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password

# ---------------- Cloudinary (for storing product images) ----------------
# Free account at https://cloudinary.com -> Dashboard shows these 3 values
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# The URL of your deployed/local frontend (used for CORS + links in emails)
CLIENT_URL=http://localhost:5173
